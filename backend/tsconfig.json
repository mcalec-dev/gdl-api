{
  "compilerOptions": {
    "target": "es6",
    "module": "commonjs",
    "allowJs": true,
    "checkJs": true,
    "noEmit": true,
    "strict": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "types": ["node"]
  },
  "include": ["utils/","api/**/*.js","models/","server.js","config.js","minify.js"],
  "exclude": ["node_modules/**/*","views/**/*","public/**/*"]
}
